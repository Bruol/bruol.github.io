---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Blog | bruol"
  description="Notes, experiments, and small updates."
>
  <section class="section-card">
    <div class="eyebrow">Blog</div>
    <h1
      class="page-title"
      style="font-size: clamp(3rem, 6vw, 4.8rem); margin-top: 1rem;"
    >
      Writing
    </h1>
    <p class="lede">
      Short notes on things I am building, testing, or learning. The content is
      deliberately lightweight, but the stack is now Astro all the way through.
    </p>
  </section>
</BaseLayout>
