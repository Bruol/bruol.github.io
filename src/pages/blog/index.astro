---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { posts } from '../../data/site.js';
---

<BaseLayout title="Blog | bruol" description="Notes, experiments, and small updates.">
  <section class="section-card">
    <div class="eyebrow">Blog</div>
    <h1 class="page-title" style="font-size: clamp(3rem, 6vw, 4.8rem); margin-top: 1rem;">Writing</h1>
    <p class="lede">
      Short notes on things I am building, testing, or learning. The content is deliberately lightweight, but the stack is now Astro all the way through.
    </p>
  </section>

  <section class="section-card">
    <div style="display:grid; gap: 1rem;">
      {posts.map((post) => (
        <a
          href={`/blog/${post.slug}/`}
          style="display:grid; gap:0.5rem; padding: 1rem 0; border-top: 1px solid var(--line);"
        >
          <div class="muted">
            {new Date(post.pubDate).toLocaleDateString('en-US', { dateStyle: 'long' })} · {post.readingTime}
          </div>
          <h2 style="margin:0; font-family: var(--serif); font-size: clamp(2rem, 4vw, 2.8rem);">
            {post.title}
          </h2>
          <p class="muted" style="margin:0;">{post.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
