---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 | bruol" description="Page not found.">
  <section class="section-card">
    <div class="eyebrow">Not Found</div>
    <h1 class="page-title" style="margin-top: 1rem;">A missing page, not a dead end.</h1>
    <p class="lede">
      The link you followed does not point to a live page in the Astro version of the site. Head back home or browse the blog instead.
    </p>
    <div class="button-row" style="margin-top: 1.5rem;">
      <a class="button primary" href="/">Go home</a>
      <a class="button secondary" href="/blog/">Open blog</a>
    </div>
  </section>
</BaseLayout>
